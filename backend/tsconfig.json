{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    // "module": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "types": ["node"],
  },
  "include": ["src"]
}
